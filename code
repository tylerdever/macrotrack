const DAYS_OF_WEEK = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];

// FIX: Use local time instead of UTC (toISOString) to prevent day shifting
const formatDateKey = (date) => {
  const year = date.getFullYear();
  const month = String(date.getMonth() + 1).padStart(2, '0');
  const day = String(date.getDate()).padStart(2, '0');
  return `${year}-${month}-${day}`;
};

const getDayName = (date) => DAYS_OF_WEEK[date.getDay()];

// --- API Helper ---

const analyzeImageWithGemini = async (base64Image, description) => {
  const apiKey = ""; // Injected by environment at runtime
  const prompt = `
    Analyze this image of food or a nutrition label. 
    User description: "${description}".
    
    1. Identify individual food items/ingredients.
    2. Estimate the quantity (amount and unit) for each.
    3. Estimate macros for EACH item specifically.
    4. Sum them up for the totals.
    
    Return strictly a JSON object with this structure:
    {
      "items": [
        {
          "name": "Food Name",
          "amount": number,
          "unit": "oz/g/cups/slice",
          "calories": number,
          "protein": number,
          "carbs": number,
          "fat": number,
          "fiber": number
        }
      ],
      "total": {
        "name": "Short meal name",
        "calories": number,
        "protein": number,
        "carbs": number,
        "fat": number,
        "fiber": number,
        "saturatedFat": number (optional),
        "sugarAlcohol": number (optional),
        "explanation": "Brief summary of what was seen"
      },
      "confidence": "high" | "medium" | "low"
    }
  `;

  try {
    const response = await fetch(
      `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`,
      {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          contents: [{
            parts: [
              { text: prompt },
              {
                inlineData: {
                  mimeType: "image/png", 
                  data: base64Image.split(',')[1] 
                }
              }
            ]
          }]
        })
      }
    );

    if (!response.ok) throw new Error('API request failed');

    const data = await response.json();
    const text = data.candidates?.[0]?.content?.parts?.[0]?.text;
    
    const jsonString = text.replace(/```json/g, '').replace(/```/g, '').trim();
    return JSON.parse(jsonString);

  } catch (error) {
    console.error("Gemini Analysis Error:", error);
    // Fallback/Mock
    return {
      items: [
        { name: "Grilled Chicken", amount: 6, unit: "oz", calories: 280, protein: 52, carbs: 0, fat: 6, fiber: 0 },
        { name: "Brown Rice", amount: 1, unit: "cup", calories: 216, protein: 5, carbs: 45, fat: 1.8, fiber: 3.5 },
      ],
      total: {
        name: "Chicken & Rice",
        calories: 496,
        protein: 57,
        carbs: 45,
        fat: 7.8,
        fiber: 3.5,
        explanation: "Simulated result: Identified grilled chicken breast and cooked brown rice."
      },
      confidence: "medium"
    };
  }
};


// --- Shared UI Components ---

const ProgressBar = ({ current, total, color, label }) => {
  const percentage = Math.min(100, Math.max(0, (current / total) * 100));
  const radius = 35;
  const circumference = 2 * Math.PI * radius;
  const strokeDashoffset = circumference - (percentage / 100) * circumference;

  return (
    <div className="flex flex-col items-center">
      <div className="relative w-20 h-20">
        <svg className="w-full h-full transform -rotate-90">
          <circle cx="40" cy="40" r={radius} stroke="currentColor" strokeWidth="6" fill="transparent" className="text-slate-200 dark:text-slate-700" />
          <circle cx="40" cy="40" r={radius} stroke={color} strokeWidth="6" fill="transparent" strokeDasharray={circumference} strokeDashoffset={strokeDashoffset} className="transition-all duration-1000 ease-out" strokeLinecap="round" />
        </svg>
        <div className="absolute inset-0 flex flex-col items-center justify-center text-xs font-bold text-slate-700 dark:text-slate-200">
          <span>{Math.round(total - current)}</span>
          <span className="text-[10px] font-normal text-slate-500">left</span>
        </div>
      </div>
      <span className="mt-1 text-xs font-medium text-slate-600 dark:text-slate-400">{label}</span>
    </div>
  );
};

