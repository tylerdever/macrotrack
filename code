};

// --- MAIN APP COMPONENT ---

export default function App() {
  // --- Global State ---
  const [view, setView] = useState('dashboard'); 
  const [activeTab, setActiveTab] = useState('home');
  const [user, setUser] = useState(null);
  const [loading, setLoading] = useState(true);
  const [isOffline, setIsOffline] = useState(false);
  
  // Data State
  const [currentDate, setCurrentDate] = useState(new Date());
  const [logs, setLogs] = useState({}); 
  const [schedule, setSchedule] = useState({}); 
  const [defaultGoals, setDefaultGoals] = useState(INITIAL_GOALS);
  const [dailyOverrides, setDailyOverrides] = useState({});

  // Analysis State (lifted up to persist during view switching if needed, though mostly handled in AnalyzeView)
  const [capturedImage, setCapturedImage] = useState(null);
  const [imageDescription, setImageDescription] = useState('');
  const [isAnalyzing, setIsAnalyzing] = useState(false);
  const [analysisResult, setAnalysisResult] = useState(null);

  // --- Derived State ---
  const currentKey = useMemo(() => formatDateKey(currentDate), [currentDate]);

  const getGoalsForDate = useCallback((date) => {
    const key = formatDateKey(date);
    const dayName = getDayName(date);
    if (dailyOverrides[key]) return dailyOverrides[key];
    if (schedule[dayName]) return schedule[dayName];
    return defaultGoals;
  }, [dailyOverrides, schedule, defaultGoals]);

  const todayGoals = useMemo(() => getGoalsForDate(currentDate), [currentDate, getGoalsForDate]);
  const todayLogs = useMemo(() => logs[currentKey] || [], [logs, currentKey]);

  const todayTotals = useMemo(() => {
    return todayLogs.reduce((acc, log) => ({
      calories: acc.calories + (log.calories || 0),
      protein: acc.protein + (log.protein || 0),
      carbs: acc.carbs + (log.carbs || 0),
      fat: acc.fat + (log.fat || 0),
      fiber: acc.fiber + (log.fiber || 0),
    }), { calories: 0, protein: 0, carbs: 0, fat: 0, fiber: 0 });
  }, [todayLogs]);

  // --- Firebase Init ---
  
  useEffect(() => {
    let isMounted = true;
    
    // Safety Timeout: Force load if Firebase is too slow (5 seconds)
    const timeoutId = setTimeout(() => {
        if (isMounted && loading) {
            console.warn("Firebase connection timed out. Forcing offline mode.");
            setIsOffline(true);
            setLoading(false);
        }
    }, 5000);

    const initAuth = async () => {
        try {
            // 1. Try secure custom token
            if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
                await signInWithCustomToken(auth, __initial_auth_token);
            } else {
                // 2. Fallback to anonymous immediately if no token
                await signInAnonymously(auth);
            }
        } catch (err) {
            console.warn("Secure auth failed, switching to anonymous fallback", err);
            try {
                // 3. Fallback to anonymous if custom token failed
                await signInAnonymously(auth);
            } catch (anonErr) {
                console.error("Critical Auth Error", anonErr);
                if (isMounted) setIsOffline(true);
            }
        }
    };
    initAuth();

    const unsubscribe = onAuthStateChanged(auth, (u) => {
        if (u && isMounted) {
            setUser(u);
            // Don't set loading false yet, wait for data sync
        }
    });

    return () => {
        isMounted = false;
        unsubscribe();
        clearTimeout(timeoutId);
    };
  }, []);

  // 2. Data Listeners (Firestore)
  useEffect(() => {
    if (!user) return;
    
    const historyRef = doc(db, 'artifacts', appId, 'users', user.uid, 'userData', 'history');
    const settingsRef = doc(db, 'artifacts', appId, 'users', user.uid, 'userData', 'settings');

    const unsubHistory = onSnapshot(historyRef, (docSnap) => {
        if (docSnap.exists()) {
            setLogs(docSnap.data());
        } else {
            setLogs({});
        }
        setLoading(false);
        setIsOffline(false);
    }, (error) => {
        console.error("History Sync Error", error);
        setLoading(false);
        setIsOffline(true); // Treat permission errors as "Offline"
    });

    const unsubSettings = onSnapshot(settingsRef, (docSnap) => {
        if (docSnap.exists()) {
            const data = docSnap.data();
            if (data.defaultGoals) setDefaultGoals(data.defaultGoals);
            if (data.schedule) setSchedule(data.schedule);
            if (data.dailyOverrides) setDailyOverrides(data.dailyOverrides);
        }
    }, (error) => console.error("Settings Sync Error", error));

    return () => {
        unsubHistory();
        unsubSettings();
    };
  }, [user?.uid]);

  // --- Firebase Handlers ---

  const getDbRefs = () => {
      // If we are offline/no user, we can't save.
      if (!user) return null;
      const historyRef = doc(db, 'artifacts', appId, 'users', user.uid, 'userData', 'history');
      const settingsRef = doc(db, 'artifacts', appId, 'users', user.uid, 'userData', 'settings');
      return { historyRef, settingsRef };
  };

  const saveLog = async (finalData) => {
    const newLog = {
      id: Date.now(),
      timestamp: Date.now(),
      ...finalData
    };
    
    // Optimistic Update
    setLogs(prev => ({
        ...prev,
        [currentKey]: [...(prev[currentKey] || []), newLog]
    }));
    setView('dashboard');
    setCapturedImage(null);
    setImageDescription('');
    setAnalysisResult(null);

    const refs = getDbRefs();
    if (refs) {
        try {
            await setDoc(refs.historyRef, { [currentKey]: arrayUnion(newLog) }, { merge: true });
        } catch (err) {
            console.error("Save Error", err);
        }
    }
  };

  const deleteLog = async (id) => {
    const currentDayLogs = logs[currentKey] || [];
    const newDayLogs = currentDayLogs.filter(l => l.id !== id);

    // Optimistic Update
    setLogs(prev => ({
        ...prev,
        [currentKey]: newDayLogs
    }));
    
    if (user) {
        const refs = getDbRefs();
        if (refs) {
            try {
                // FIX: Use setDoc with merge instead of updateDoc to prevent "document not found" errors
                await setDoc(refs.historyRef, { [currentKey]: newDayLogs }, { merge: true });
            } catch (err) {
                console.error("Delete Error", err);
            }
        }
    }
  };

  const updateSchedule = async (day, goals) => {
      let newSchedule = { ...schedule };
      if (goals === null) {
          delete newSchedule[day];
      } else {
          newSchedule[day] = goals;
      }
      setSchedule(newSchedule); // Optimistic

      const refs = getDbRefs();
      if (refs) await setDoc(refs.settingsRef, { schedule: newSchedule }, { merge: true });
  };

  const updateDefaultGoals = async (newGoals) => {
      setDefaultGoals(newGoals); // Optimistic
      const refs = getDbRefs();
      if (refs) await setDoc(refs.settingsRef, { defaultGoals: newGoals }, { merge: true });
  };

  const updateDailyOverrides = async (goals) => {
      setDailyOverrides(prev => ({ ...prev, [currentKey]: goals })); // Optimistic
      const refs = getDbRefs();
      if (refs) await setDoc(refs.settingsRef, { dailyOverrides: { ...dailyOverrides, [currentKey]: goals } }, { merge: true });
  };

  // --- Main Render ---

  if (loading) {
      return (
        <div className="max-w-md mx-auto h-[100dvh] flex flex-col bg-slate-50 dark:bg-slate-900 items-center justify-center p-6 text-center">
            <Loader2 className="w-10 h-10 text-blue-500 animate-spin mb-4" />
            <p className="text-slate-500 text-sm font-medium">Starting App...</p>
        </div>
      );
  }

  return (
    <div className="max-w-md mx-auto h-[100dvh] flex flex-col bg-slate-50 dark:bg-slate-900 font-sans text-slate-900 dark:text-slate-100 overflow-hidden relative shadow-2xl">
      <style>{`
        .scrollbar-hide::-webkit-scrollbar {
            display: none;
        }
        .scrollbar-hide {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
      `}</style>

      {/* View Content */}
      <div className="flex-1 overflow-y-auto scrollbar-hide">
        {view === 'dashboard' && (
          <DashboardView 
            currentDate={currentDate} 
            setCurrentDate={setCurrentDate}
            currentKey={currentKey}
            todayGoals={todayGoals}
            todayTotals={todayTotals}
            todayLogs={todayLogs}
            deleteLog={deleteLog}
            setView={setView}
          />
        )}
        
        {view === 'analyze' && (
          <AnalyzeView 
            capturedImage={capturedImage}
            setCapturedImage={setCapturedImage}
            imageDescription={imageDescription}
            setImageDescription={setImageDescription}
            isAnalyzing={isAnalyzing}
            setIsAnalyzing={setIsAnalyzing}
            analysisResult={analysisResult}
            setAnalysisResult={setAnalysisResult}
            setView={setView}
            saveLog={saveLog}
          />
        )}
        
        {view === 'calendar' && (
          <CalendarPage 
            currentDate={currentDate}
            setCurrentDate={setCurrentDate}
            setView={setView}
            setActiveTab={setActiveTab}
            logs={logs}
          />
        )}
        
        {view === 'settings' && (
          <SettingsView 
            schedule={schedule}
            setSchedule={setSchedule}
            defaultGoals={defaultGoals}
            setDefaultGoals={setDefaultGoals}
            updateSchedule={updateSchedule}
            handleGoalChange={updateDefaultGoals}
            isOffline={isOffline}
          />
        )}
        
        {view === 'edit-goals' && (
          <SingleDayEditView 
            currentKey={currentKey}
            todayGoals={todayGoals}
            setDailyOverrides={updateDailyOverrides}
            setView={setView}
          />
        )}
      </div>

      {/* Navigation Bar */}
      {view !== 'analyze' && view !== 'edit-goals' && (
        <div className="bg-white dark:bg-slate-800 border-t border-slate-100 dark:border-slate-700 px-6 py-4 flex justify-between items-center pb-8 safe-area-pb">
          <button 
            onClick={() => { setView('dashboard'); setActiveTab('home'); }} 
            className={`flex flex-col items-center gap-1 ${activeTab === 'home' ? 'text-blue-600' : 'text-slate-400'}`}
          >
            <Home size={24} strokeWidth={activeTab === 'home' ? 3 : 2} />
            <span className="text-[10px] font-medium">Daily</span>
          </button>

          <button 
            onClick={() => { setView('calendar'); setActiveTab('calendar'); }}
            className={`flex flex-col items-center gap-1 ${activeTab === 'calendar' ? 'text-blue-600' : 'text-slate-400'}`}
          >
            <History size={24} strokeWidth={activeTab === 'calendar' ? 3 : 2} />
            <span className="text-[10px] font-medium">History</span>
          </button>

          <button 
            onClick={() => { setView('analyze'); setCapturedImage(null); }}
            className="flex items-center justify-center w-14 h-14 bg-blue-600 text-white rounded-full shadow-lg shadow-blue-200 hover:scale-105 transition-transform -mt-6 border-4 border-slate-50 dark:border-slate-900"
          >
            <Plus size={28} strokeWidth={3} />
          </button>

          <button 
            onClick={() => { setView('settings'); setActiveTab('settings'); }}
            className={`flex flex-col items-center gap-1 ${activeTab === 'settings' ? 'text-blue-600' : 'text-slate-400'}`}
          >
            <Settings size={24} strokeWidth={activeTab === 'settings' ? 3 : 2} />
            <span className="text-[10px] font-medium">Plan</span>
          </button>
        </div>
      )}
    </div>
  );
}

